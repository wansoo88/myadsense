# .env.example — 키 목록만. 실제 값은 .env (git 커밋 금지)

# Google API (읽기 — 자동화 핵심)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
ADSENSE_ACCOUNT_ID=             # pub-XXXXXXXXXXXXXXXX
SEARCH_CONSOLE_SITE_URL=        # https://example.com/
PAGESPEED_API_KEY=

# Claude API (콘텐츠 생성)
ANTHROPIC_API_KEY=

# CMS 발행 어댑터 (sites.yaml 에서 택1)
WP_USER=                        # wordpress
WP_APP_PASSWORD=                # wordpress 앱 비밀번호
GIT_REMOTE=                     # static_ssg

# 알림
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
